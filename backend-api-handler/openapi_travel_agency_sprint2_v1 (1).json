    "/reports/download": {
      "get": {
        "tags": ["Reports"],
        "summary": "Download Report (User Story 11, Optional)",
        "description": "Downloads the report in the requested format (PDF, Excel, CSV) based on the cached report data.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cachedReportKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique key identifying the cached report data."
          },
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["pdf", "excel", "csv"]
            },
            "description": "The desired format for the report (pdf, excel, csv)."
          }
        ],
        "responses": {
          "200": {
            "description": "Report file link retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DownloadReportResponseDTO"
                },
                "examples": {
                  "example-1": {
                    "value": {
                      "fileUrl": "https://travel-agency-app.s3.amazonaws.com/reports/abc123/report.pdf"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Cached report data not found or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Cached report data not found or expired."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
