              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "message": "Verification code validated successfully."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid verification code.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "error": "Invalid verification code."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Email not found.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "error": "Email not found."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to validate verification code.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "error": "Failed to validate verification code. Please try again later."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Enter New Password (User Story 13, Optional)",
        "description": "This endpoint allows the user to reset their password using the verification code.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "verificationCode": {
                    "type": "string"
                  },
                  "newPassword": {
                    "type": "string"
                  }
                },
                "required": ["email", "verificationCode", "newPassword"]
              },
              "examples": {
                "example-1": {
                  "value": {
                    "email": "user@example.com",
                    "verificationCode": "123456",
                    "newPassword": "NewSecurePassword123!"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successfully.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "message": "Password reset successfully."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid verification code.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "error": "Invalid verification code."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Email not found.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "error": "Email not found."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to reset password.",
            "content": {
              "application/json": {
                "examples": {
                  "example-1": {
                    "value": {
                      "error": "Failed to reset password. Please try again later."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/reports/generate": {
      "post": {
        "tags": ["Reports"],
        "summary": "Generate Report (User Story 11, Optional)",
        "description": "Generates report data based on the user's input and returns the data in JSON format.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
